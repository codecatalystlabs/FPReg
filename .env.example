# Server
APP_PORT=8080
APP_ENV=development
GIN_MODE=debug

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_password_here
DB_NAME=fpreg
DB_SSLMODE=disable
DB_TIMEZONE=Africa/Kampala

# JWT
JWT_SECRET=change-this-to-a-strong-random-secret-min-32-chars
JWT_ACCESS_EXPIRY_MINUTES=30
JWT_REFRESH_EXPIRY_HOURS=168

# Seed admin (created on first run)
SEED_ADMIN_EMAIL=admin@moh.go.ug
SEED_ADMIN_PASSWORD=ChangeMe@2026!
SEED_ADMIN_NAME=System Administrator

# Logging
LOG_LEVEL=debug
LOG_FILE=logs/app.log
AUDIT_LOG_FILE=logs/audit.log
SECURITY_LOG_FILE=logs/security.log
